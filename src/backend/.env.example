# ── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://forge:forge@localhost:5432/forge

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_BROKER_URL=redis://localhost:6379/0
REDIS_CHANNELS_URL=redis://localhost:6379/1

# ── Encryption (WorkspaceSecret champs chiffrés AES-256) ─────────────────────
# Générer avec: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=change-me-generate-with-fernet

# ── Django CORS ───────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Email (optionnel, dev) ───────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# ── S3 / Backups ─────────────────────────────────────────────────────────────
# S3_BUCKET_NAME=webtech-forge-backups
# S3_ENDPOINT_URL=https://s3.fr-par.scw.cloud
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=fr-par

# ── Registry Docker local ─────────────────────────────────────────────────────
REGISTRY_HOST=localhost:5000
